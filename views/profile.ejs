<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <div class="container nav-content">
            <a href="/" class="brand">CampusLost</a>
            <div class="nav-links">
                <a href="/items">Browse</a>
                <a href="/report">Report Item</a>
                <% if (user) { %>
                    <% if (user.isAdmin) { %>
                        <a href="/admin">Dashboard</a>
                    <% } %>
                    <a href="/profile" class="active">My Claims</a>
                    <a href="/logout">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container" style="margin-top: 4rem;">
        <h1>Welcome, <%= user.username %>!</h1>
        <p style="color: #94a3b8; margin-bottom: 3rem;">Track your reports and claims here.</p>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;">
            <div>
                <h2 style="margin-bottom: 2rem;">Items You've Reported</h2>
                <% if (myItems.length > 0) { %>
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        <% myItems.forEach(item => { %>
                            <div style="background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <h3 style="margin: 0;"><%= item.title %></h3>
                                    <p style="color: #94a3b8; font-size: 0.85rem;"><%= item.location %> • <%= item.itemType %></p>
                                </div>
                                <span style="background: <%= item.status === 'open' ? 'rgba(99, 102, 241, 0.2)' : 'rgba(34, 197, 94, 0.2)' %>; color: <%= item.status === 'open' ? '#6366f1' : '#22c55e' %>; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 700;">
                                    <%= item.status %>
                                </span>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p style="color: #94a3b8;">You haven't reported any items yet.</p>
                <% } %>
            </div>

            <div>
                <h2 style="margin-bottom: 2rem;">Your Claims</h2>
                <% if (myClaims.length > 0) { %>
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        <% myClaims.forEach(claim => { %>
                            <div style="background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <h3 style="margin: 0;"><%= claim.item.title %></h3>
                                    <p style="color: #94a3b8; font-size: 0.85rem;">Status: <%= claim.status %></p>
                                </div>
                                <% if (claim.status === 'approved') { %>
                                    <span style="color: #22c55e; font-weight: 700;">✅ Approved</span>
                                <% } else if (claim.status === 'rejected') { %>
                                    <span style="color: #f43f5e; font-weight: 700;">❌ Rejected</span>
                                <% } else { %>
                                    <span style="color: #eab308; font-weight: 700;">⌛ Pending</span>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p style="color: #94a3b8;">You haven't submitted any claims yet.</p>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
