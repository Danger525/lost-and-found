<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <div class="container nav-content">
            <a href="/" class="brand">CampusLost</a>
            <div class="nav-links">
                <a href="/items">Browse</a>
                <a href="/items/report">Report Item</a>
                <% if (user) { %>
                    <% if (user.isAdmin) { %>
                        <a href="/admin/dashboard">Dashboard</a>
                    <% } %>
                    <a href="/<%= user.username %>/items">My Items</a>
                    <a href="/<%= user.username %>/claims">My Claims</a>
                    <a href="/logout">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="container">
        <section class="hero">
            <h1>Lost it? Find it.<br>Found it? Return it.</h1>
            <p>The smartest way to reconnect belongings with their owners within our campus community.</p>
            <div style="display: flex; gap: 1.5rem; justify-content: center;">
                <a href="/items/report" class="btn btn-primary">Report Found Item</a>
                <a href="/items" class="btn btn-outline">Browse All Items</a>
            </div>
        </section>
    </main>
</body>
</html>
