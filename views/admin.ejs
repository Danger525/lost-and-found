<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }
        .stat-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 1.5rem;
            border-radius: 20px;
            text-align: center;
        }
        .stat-value { font-size: 2rem; font-weight: 800; color: #6366f1; display: block; }
        .stat-label { color: #94a3b8; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; }

        .dashboard-tabs {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding-bottom: 1rem;
        }
        .tab-btn {
            background: transparent;
            border: none;
            color: #94a3b8;
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
        }
        .tab-btn:hover { background: rgba(255,255,255,0.05); }
        .tab-btn.active { background: #6366f1; color: white; }

        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeIn 0.4s ease; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .admin-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 1.5rem;
            border-radius: 16px;
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .badge { padding: 0.25rem 0.6rem; border-radius: 6px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
        .badge-pending { background: rgba(234, 179, 8, 0.1); color: #eab308; }
        .badge-approved { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
        .badge-open { background: rgba(99, 102, 241, 0.1); color: #6366f1; }
        .badge-returned { background: rgba(34, 197, 94, 0.1); color: #22c55e; }

        table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
        th { text-align: left; padding: 1rem; color: #94a3b8; font-size: 0.8rem; text-transform: uppercase; }
        td { padding: 1rem; border-top: 1px solid rgba(255,255,255,0.05); }
        tr:hover td { background: rgba(255,255,255,0.02); }

        .btn-small { padding: 0.4rem 0.8rem; font-size: 0.75rem; }
        .btn-danger { background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 1px solid rgba(244, 63, 94, 0.2); }
        .btn-danger:hover { background: #f43f5e; color: white; }

        .action-group { display: flex; gap: 0.5rem; }
    </style>
</head>
<body>
    <nav>
        <div class="container nav-content">
            <a href="/" class="brand">CampusLost</a>
            <div class="nav-links">
                <a href="/items">Browse</a>
                <a href="/report">Report Item</a>
                <a href="/admin" class="active">Dashboard</a>
                <a href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container" style="margin-top: 4rem;">
        <header style="margin-bottom: 3rem;">
            <h1>Global Command Center</h1>
            <p style="color: #94a3b8;">System-wide management of all users, items, and claims.</p>
        </header>

        <% if (success_msg && success_msg.length > 0) { %>
            <div style="background: rgba(34, 197, 94, 0.1); color: #22c55e; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(34, 197, 94, 0.2);">
                <%= success_msg %>
            </div>
        <% } %>

        <% if (error_msg && error_msg.length > 0) { %>
            <div style="background: rgba(244, 63, 94, 0.1); color: #f43f5e; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(244, 63, 94, 0.2);">
                <%= error_msg %>
            </div>
        <% } %>

        <!-- Stats Overview -->
        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-value"><%= userCount %></span>
                <span class="stat-label">Total Users</span>
            </div>
            <div class="stat-card">
                <span class="stat-value"><%= itemCount %></span>
                <span class="stat-label">Global Items</span>
            </div>
            <div class="stat-card">
                <span class="stat-value"><%= claimCount %></span>
                <span class="stat-label">Total Claims</span>
            </div>
        </div>

        <!-- Tab Controls -->
        <div class="dashboard-tabs">
            <button class="tab-btn active" onclick="showTab('claims')">Incoming Claims</button>
            <button class="tab-btn" onclick="showTab('inventory')">Global Inventory</button>
            <button class="tab-btn" onclick="showTab('users')">User Directory</button>
        </div>

        <!-- Claims Tab -->
        <div id="claims" class="tab-content active">
            <% if (claims.length > 0) { %>
                <% claims.forEach(claim => { %>
                    <div class="admin-card">
                        <div style="flex: 1;">
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                                <h3 style="margin:0;"><%= claim.item ? claim.item.title : 'Deleted Item' %></h3>
                                <span class="badge badge-<%= claim.status %>"><%= claim.status %></span>
                            </div>
                            <p style="font-size: 0.85rem; color: #94a3b8;">
                                <strong>From:</strong> <%= claim.claimer.username %> (<%= claim.claimer.email %>)
                            </p>
                            <p style="margin-top: 0.5rem; font-style: italic; color: #cbd5e1; font-size: 0.9rem;">"<%= claim.description %>"</p>
                        </div>
                        
                        <% if (claim.status === 'pending') { %>
                            <div class="action-group">
                                <form action="/admin/claims/<%= claim._id %>/approve" method="POST">
                                    <button class="btn btn-primary btn-small">Approve</button>
                                </form>
                                <form action="/admin/claims/<%= claim._id %>/reject" method="POST">
                                    <button class="btn btn-outline btn-small" style="color: #f43f5e; border-color: #f43f5e;">Reject</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="color: #94a3b8; text-align: center; padding: 3rem;">No claims have been submitted yet.</p>
            <% } %>
        </div>

        <!-- Inventory Tab -->
        <div id="inventory" class="tab-content">
            <% if (items.length > 0) { %>
                <% items.forEach(item => { %>
                    <div class="admin-card">
                        <div style="display: flex; align-items: center; gap: 1.5rem;">
                            <img src="<%= item.imageUrl %>" style="width: 50px; height: 50px; border-radius: 8px; object-fit: cover; background: #1a1a1a;">
                            <div>
                                <h4 style="margin:0;"><%= item.title %></h4>
                                <p style="font-size: 0.75rem; color: #6366f1;">Reported by: <%= item.reporter ? item.reporter.username : 'Unknown' %></p>
                            </div>
                            <span class="badge badge-<%= item.status %>"><%= item.status %></span>
                        </div>
                        <div class="action-group">
                            <form action="/admin/items/<%= item._id %>/status" method="POST">
                                <select name="status" onchange="this.form.submit()" style="background: rgba(0,0,0,0.3); color: white; border: 1px solid rgba(255,255,255,0.1); padding: 0.4rem; border-radius: 8px; font-size: 0.8rem;">
                                    <option value="open" <%= item.status === 'open' ? 'selected' : '' %>>Open</option>
                                    <option value="returned" <%= item.status === 'returned' ? 'selected' : '' %>>Returned</option>
                                </select>
                            </form>
                            <form action="/admin/items/<%= item._id %>/delete" method="POST" onsubmit="return confirm('Permanently delete this item?')">
                                <button class="btn btn-danger btn-small">Delete</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="color: #94a3b8; text-align: center; padding: 3rem;">Inventory is empty.</p>
            <% } %>
        </div>

        <!-- User Directory Tab -->
        <div id="users" class="tab-content">
            <div style="background: rgba(255,255,255,0.02); border-radius: 20px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden;">
                <table>
                    <thead>
                        <tr>
                            <th>User Info</th>
                            <th>Role</th>
                            <th>Registration Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u => { %>
                            <tr>
                                <td>
                                    <div style="font-weight: 600;"><%= u.username %></div>
                                    <div style="font-size: 0.8rem; color: #94a3b8;"><%= u.email %></div>
                                </td>
                                <td>
                                    <span style="font-size: 0.7rem; padding: 2px 8px; border-radius: 4px; background: <%= u.isAdmin ? 'rgba(99,102,241,0.2)' : 'rgba(255,255,255,0.05)' %>; color: <%= u.isAdmin ? '#6366f1' : '#94a3b8' %>">
                                        <%= u.isAdmin ? 'ADMIN' : 'STUDENT' %>
                                    </span>
                                </td>
                                <td style="color: #64748b; font-size: 0.9rem;">
                                    <%= u.createdAt.toLocaleDateString() %>
                                </td>
                                <td>
                                    <% if (u._id.toString() !== user.id.toString()) { %>
                                        <form action="/admin/users/<%= u._id %>/delete" method="POST" onsubmit="return confirm('Delete this user account?')">
                                            <button class="btn btn-danger btn-small">Remove</button>
                                        </form>
                                    <% } else { %>
                                        <span style="font-size: 0.75rem; color: #6366f1; font-weight: 600;">YOU</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        function showTab(tabId) {
            // Remove active class from all buttons and contents
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            
            // Add active class to selected button and content
            document.querySelector(`[onclick="showTab('${tabId}')"]`).classList.add('active');
            document.getElementById(tabId).classList.add('active');
        }
    </script>
</body>
</html>
