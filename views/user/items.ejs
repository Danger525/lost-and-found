<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <div class="container nav-content">
            <a href="/" class="brand">CampusLost</a>
            <div class="nav-links">
                <a href="/items">Browse</a>
                <a href="/items/report">Report Item</a>
                <% if (user) { %>
                    <% if (user.isAdmin) { %>
                        <a href="/admin/dashboard">Dashboard</a>
                    <% } %>
                    <a href="/<%= user.username %>/items" class="<%= user.username === userProfile.username ? 'active' : '' %>">My Items</a>
                    <a href="/<%= user.username %>/claims">My Claims</a>
                    <a href="/logout">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container" style="margin-top: 4rem;">
        <header style="margin-bottom: 3rem;">
            <h1>Found by <%= userProfile.username %></h1>
            <p style="color: #94a3b8; margin-top: 0.5rem;">Collection of items reported by this user.</p>
        </header>

        <% if (items.length > 0) { %>
            <div class="items-grid">
                <% items.forEach(item => { %>
                    <a href="/items/<%= item._id %>" class="item-card">
                        <div class="item-image-wrapper">
                            <img src="<%= item.imageUrl || 'https://images.unsplash.com/photo-1582139329536-e7284fece509?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60' %>" loading="lazy">
                            <span class="type-badge <%= item.itemType %>"><%= item.itemType %></span>
                        </div>
                        <div class="item-info">
                            <h3><%= item.title %></h3>
                            <div class="item-meta">
                                <span>📍 <%= item.location %></span>
                                <span class="status-badge status-<%= item.status %>"><%= item.status %></span>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 5rem; background: rgba(255,255,255,0.02); border-radius: 20px;">
                <p style="color: #94a3b8;">No items have been reported in this gallery yet.</p>
                <% if (user && user.username === userProfile.username) { %>
                    <a href="/items/report" class="btn btn-primary" style="margin-top: 1rem; display: inline-block;">Report Your First Item</a>
                <% } %>
            </div>
        <% } %>
    </div>
</body>
</html>
