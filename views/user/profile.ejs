<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <div class="container nav-content">
            <a href="/" class="brand">CampusLost</a>
            <div class="nav-links">
                <a href="/items">Browse</a>
                <a href="/items/report">Report Item</a>
                <% if (user) { %>
                    <% if (user.isAdmin) { %>
                        <a href="/admin/dashboard">Dashboard</a>
                    <% } %>
                    <a href="/<%= user.username %>/items">My Items</a>
                    <a href="/logout">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container" style="margin-top: 4rem;">
        <div class="dashboard-card" style="padding: 3rem; text-align: center;">
            <div style="width: 100px; height: 100px; background: #6366f1; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto; font-size: 2.5rem; font-weight: 800; color: white;">
                <%= userProfile.username.charAt(0).toUpperCase() %>
            </div>
            <h1 style="margin-bottom: 0.5rem;"><%= userProfile.username %></h1>
            <p style="color: #94a3b8; margin-bottom: 2rem;">Member since <%= userProfile.createdAt.toLocaleDateString() %></p>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 500px; margin: 0 auto;">
                <a href="/<%= userProfile.username %>/items" class="stat-card" style="text-decoration: none;">
                    <span class="stat-value"><%= itemCount %></span>
                    <span class="stat-label">Items Found</span>
                </a>
                <a href="/<%= userProfile.username %>/claims" class="stat-card" style="text-decoration: none;">
                    <span class="stat-value"><%= claimCount %></span>
                    <span class="stat-label">Active Claims</span>
                </a>
            </div>

            <div style="margin-top: 3rem;">
                <p style="color: #64748b; font-size: 0.9rem;">Email Address: <span style="color: #f1f5f9;"><%= userProfile.email %></span></p>
            </div>
        </div>
    </div>
</body>
</html>
