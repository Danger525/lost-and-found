<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <div class="container nav-content">
            <a href="/" class="brand">CampusLost</a>
            <div class="nav-links">
                <a href="/items">Browse</a>
                <a href="/items/report">Report Item</a>
                <% if (user) { %>
                    <% if (user.isAdmin) { %>
                        <a href="/admin/dashboard">Dashboard</a>
                    <% } %>
                    <a href="/<%= user.username %>/items">My Items</a>
                    <a href="/<%= user.username %>/claims" class="active">My Claims</a>
                    <a href="/logout">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container" style="margin-top: 4rem;">
        <header style="margin-bottom: 3rem;">
            <h1>My Active Claims</h1>
            <p style="color: #94a3b8; margin-top: 0.5rem;">Track the status of belongings you've requested to recover.</p>
        </header>

        <% if (claims.length > 0) { %>
            <div style="display: grid; gap: 1.5rem;">
                <% claims.forEach(claim => { %>
                    <div class="card" style="display: flex; flex-direction: row; align-items: center; padding: 1.25rem; gap: 2rem;">
                        <img src="<%= (claim.item && claim.item.imageUrl) ? claim.item.imageUrl : 'https://images.unsplash.com/photo-1574634534894-89d7576c8259?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60' %>" style="width: 100px; height: 100px; border-radius: 16px; object-fit: cover; flex-shrink: 0;">
                        
                        <div style="flex: 1;">
                            <h3 style="margin-bottom: 0.5rem;"><%= claim.item ? claim.item.title : 'Deleted Item' %></h3>
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <span class="status-badge status-<%= claim.status %>"><%= claim.status %></span>
                                <% if (claim.item) { %>
                                    <span style="font-size: 0.8rem; color: #6366f1; font-weight: 600;">📍 <%= claim.item.location %></span>
                                <% } %>
                            </div>
                        </div>

                        <div style="text-align: right; padding-right: 1rem;">
                            <p style="font-size: 0.7rem; color: #94a3b8; text-transform: uppercase; font-weight: 800; letter-spacing: 1px; margin-bottom: 0.25rem;">Submitted On</p>
                            <p style="font-weight: 700; color: #f1f5f9;"><%= claim.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                            <% if (claim.status === 'pending') { %>
                                <p style="font-size: 0.75rem; color: #eab308; margin-top: 0.5rem;">Under Review</p>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 5rem; background: rgba(255,255,255,0.02); border-radius: 20px; border: 1px dashed rgba(255,255,255,0.1);">
                <p style="color: #94a3b8;">You haven't made any recovery claims yet.</p>
                <a href="/items" class="btn btn-primary" style="margin-top: 1.5rem; display: inline-block;">Browse Community Items</a>
            </div>
        <% } %>
    </div>
</body>
</html>
