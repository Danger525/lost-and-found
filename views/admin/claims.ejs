<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        body { display: flex; min-height: 100vh; overflow-x: hidden; }
        
        .sidebar {
            width: 280px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid rgba(255,255,255,0.05);
            padding: 2rem;
            display: flex; flex-direction: column; position: fixed; height: 100vh;
        }
        .sidebar-brand { font-size: 1.5rem; font-weight: 800; color: #6366f1; margin-bottom: 3rem; text-decoration: none; }
        .sidebar-nav { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
        .nav-item {
            padding: 1rem; border-radius: 12px; color: #94a3b8; text-decoration: none;
            transition: all 0.3s; font-weight: 600; display: flex; align-items: center; gap: 1rem;
        }
        .nav-item:hover { background: rgba(255,255,255,0.05); color: white; }
        .nav-item.active { background: #6366f1; color: white; }
        
        .main-content { margin-left: 280px; flex: 1; padding: 3rem; }

        .claim-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 1.5rem;
            border-radius: 20px;
            margin-bottom: 1.5rem;
            transition: all 0.3s;
        }
        .claim-card:hover { border-color: #6366f1; background: rgba(255,255,255,0.03); }

        .proof-box {
            background: rgba(0,0,0,0.2);
            padding: 1.25rem;
            border-radius: 12px;
            margin: 1rem 0;
            border-left: 3px solid #6366f1;
        }

        .action-btns { display: flex; gap: 1rem; margin-top: 1.5rem; }
        .badge { padding: 0.25rem 0.6rem; border-radius: 6px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
        .badge-pending { background: rgba(234, 179, 8, 0.15); color: #eab308; }
        .badge-approved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
        .badge-rejected { background: rgba(244, 63, 94, 0.15); color: #f43f5e; }
        
        .item-preview { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.05); }
    </style>
</head>
<body>
    <aside class="sidebar">
        <a href="/" class="sidebar-brand">CampusLost</a>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">🏠 Dashboard</a>
            <a href="/admin/claims" class="nav-item active">📋 Global Claims</a>
            <a href="/admin/items" class="nav-item">📦 Global Items</a>
            <a href="/admin/users" class="nav-item">👥 User Directory</a>
            <a href="/items" class="nav-item">🌐 Browse View</a>
        </nav>
        <div style="margin-top: auto; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.05);">
            <a href="/logout" class="nav-item">🚪 Logout</a>
        </div>
    </aside>

    <main class="main-content">
        <header style="margin-bottom: 3rem;">
            <h1>Global Claim Verification</h1>
            <p style="color: #94a3b8; margin-top: 0.5rem;">Review evidence provided by claimants and verify ownership globally.</p>
        </header>

        <% if (success_msg && success_msg.length > 0) { %>
            <div style="background: rgba(34, 197, 94, 0.1); color: #22c55e; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(34, 197, 94, 0.2);">
                <%= success_msg %>
            </div>
        <% } %>

        <% if (claims.length > 0) { %>
            <% claims.forEach(claim => { %>
                <div class="claim-card">
                    <div class="item-preview">
                        <img src="<%= (claim.item && claim.item.imageUrl) ? claim.item.imageUrl : 'https://images.unsplash.com/photo-1574634534894-89d7576c8259?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60' %>" style="width: 50px; height: 50px; border-radius: 10px; object-fit: cover; background: #1a1a1a;">
                        <div style="flex: 1;">
                            <h3 style="margin:0;"><%= claim.item ? claim.item.title : 'Deleted Item' %></h3>
                            <span class="badge badge-<%= claim.status %>"><%= claim.status %></span>
                        </div>
                        <div style="text-align: right;">
                            <span style="font-size: 0.75rem; color: #94a3b8; display: block;">Claim Date</span>
                            <span style="font-weight: 600;"><%= claim.createdAt.toLocaleDateString() %></span>
                        </div>
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 2rem;">
                        <div style="flex: 1;">
                            <span style="font-size: 0.75rem; color: #6366f1; text-transform: uppercase; font-weight: 800; letter-spacing: 1px;">Evidence Provided</span>
                            <div class="proof-box">
                                <p style="line-height: 1.6;"><%= claim.description %></p>
                            </div>
                        </div>
                        <div style="background: rgba(255,255,255,0.02); padding: 1.25rem; border-radius: 12px; width: 250px;">
                            <span style="font-size: 0.75rem; color: #94a3b8; text-transform: uppercase;">Claimant Profile</span>
                            <p style="font-weight: 700; margin: 0.5rem 0 0.25rem 0;"><%= claim.claimer.username %></p>
                            <p style="font-size: 0.85rem; color: #6366f1;"><%= claim.claimer.email %></p>
                            <p style="font-size: 0.8rem; color: #94a3b8; margin-top: 1rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 0.5rem;">
                                Contact: <%= claim.contactDetails %>
                            </p>
                        </div>
                    </div>

                    <% if (claim.status === 'pending') { %>
                        <div class="action-btns">
                            <form action="/admin/claims/<%= claim._id %>/approve" method="POST" style="flex: 1;">
                                <button type="submit" class="btn btn-primary" style="width: 100%;">Verify & Approve</button>
                            </form>
                            <form action="/admin/claims/<%= claim._id %>/reject" method="POST" style="flex: 1;">
                                <button type="submit" class="btn btn-outline" style="width: 100%; color: #f43f5e; border-color: #f43f5e;">Reject Claim</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <div style="text-align: center; padding: 5rem; background: rgba(255,255,255,0.01); border-radius: 20px; border: 1px dashed rgba(255,255,255,0.1);">
                <p style="color: #94a3b8;">No pending claims in the system.</p>
            </div>
        <% } %>
    </main>
</body>
</html>
