<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        body { display: flex; min-height: 100vh; overflow-x: hidden; }
        
        .sidebar {
            width: 280px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid rgba(255,255,255,0.05);
            padding: 2rem;
            display: flex; flex-direction: column; position: fixed; height: 100vh;
        }
        .sidebar-brand { font-size: 1.5rem; font-weight: 800; color: #6366f1; margin-bottom: 3rem; text-decoration: none; }
        .sidebar-nav { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
        .nav-item {
            padding: 1rem; border-radius: 12px; color: #94a3b8; text-decoration: none;
            transition: all 0.3s; font-weight: 600; display: flex; align-items: center; gap: 1rem;
        }
        .nav-item:hover { background: rgba(255,255,255,0.05); color: white; }
        .nav-item.active { background: #6366f1; color: white; }
        
        .main-content { margin-left: 280px; flex: 1; padding: 3rem; }

        .user-table-container {
            background: rgba(255,255,255,0.02);
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.05);
            overflow: hidden;
            margin-top: 1rem;
        }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 1.25rem 1.5rem; color: #94a3b8; font-size: 0.8rem; text-transform: uppercase; background: rgba(255,255,255,0.01); }
        td { padding: 1.25rem 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); vertical-align: middle; }
        tr:hover td { background: rgba(255,255,255,0.02); }

        .role-badge { 
            font-size: 0.65rem; padding: 4px 10px; border-radius: 6px; font-weight: 800;
            letter-spacing: 0.5px;
        }
        .role-admin { background: rgba(99, 102, 241, 0.15); color: #6366f1; border: 1px solid rgba(99, 102, 241, 0.2); }
        .role-student { background: rgba(255,255,255,0.05); color: #94a3b8; }

        .btn-danger-outline {
            background: transparent;
            color: #f43f5e;
            border: 1px solid rgba(244, 63, 94, 0.3);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .btn-danger-outline:hover { background: #f43f5e; color: white; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <a href="/" class="sidebar-brand">CampusLost</a>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">🏠 Dashboard</a>
            <a href="/admin/claims" class="nav-item">📋 Global Claims</a>
            <a href="/admin/items" class="nav-item">📦 Global Items</a>
            <a href="/admin/users" class="nav-item active">👥 User Directory</a>
            <a href="/items" class="nav-item">🌐 Browse View</a>
        </nav>
        <div style="margin-top: auto; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.05);">
            <a href="/logout" class="nav-item">🚪 Logout</a>
        </div>
    </aside>

    <main class="main-content">
        <header style="margin-bottom: 3rem;">
            <h1>User Directory</h1>
            <p style="color: #94a3b8; margin-top: 0.5rem;">Audit system users and manage administrative permissions.</p>
        </header>

        <% if (success_msg && success_msg.length > 0) { %>
            <div style="background: rgba(34, 197, 94, 0.1); color: #22c55e; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(34, 197, 94, 0.2);">
                <%= success_msg %>
            </div>
        <% } %>

        <% if (error_msg && error_msg.length > 0) { %>
            <div style="background: rgba(244, 63, 94, 0.1); color: #f43f5e; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(244, 63, 94, 0.2);">
                <%= error_msg %>
            </div>
        <% } %>

        <div class="user-table-container">
            <table>
                <thead>
                    <tr>
                        <th>User Identifier</th>
                        <th>Registered Email</th>
                        <th>Platform Role</th>
                        <th>Joined Date</th>
                        <th style="text-align: right;">Management</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td>
                                <div style="font-weight: 700; color: #f8fafc;"><%= u.username %></div>
                                <div style="font-size: 0.7rem; color: #6366f1; opacity: 0.8;">UID: <%= u._id.toString().substring(0, 8) %>...</div>
                            </td>
                            <td>
                                <div style="color: #cbd5e1; font-size: 0.9rem;"><%= u.email %></div>
                            </td>
                            <td>
                                <span class="role-badge role-<%= u.isAdmin ? 'admin' : 'student' %>">
                                    <%= u.isAdmin ? 'ADMINISTRATOR' : 'STUDENT' %>
                                </span>
                            </td>
                            <td style="color: #94a3b8; font-size: 0.85rem;">
                                <%= u.createdAt ? u.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Unknown' %>
                            </td>
                            <td style="text-align: right;">
                                <% if (u._id.toString() !== user.id.toString()) { %>
                                    <!-- Fixed User Removal Form -->
                                    <form action="/admin/users/<%= u._id %>/delete" method="POST" onsubmit="return confirm('CRITICAL: Delete this user account? This cannot be undone.')">
                                        <button type="submit" class="btn-danger-outline">Remove User</button>
                                    </form>
                                <% } else { %>
                                    <span style="color: #6366f1; font-size: 0.75rem; font-weight: 800; letter-spacing: 1px;">ACTIVE SESSION</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>
