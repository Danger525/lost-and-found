<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        body { display: flex; min-height: 100vh; overflow-x: hidden; }
        
        .sidebar {
            width: 280px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid rgba(255,255,255,0.05);
            padding: 2rem;
            display: flex; flex-direction: column; position: fixed; height: 100vh;
        }
        .sidebar-brand { font-size: 1.5rem; font-weight: 800; color: #6366f1; margin-bottom: 3rem; text-decoration: none; }
        .sidebar-nav { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
        .nav-item {
            padding: 1rem; border-radius: 12px; color: #94a3b8; text-decoration: none;
            transition: all 0.3s; font-weight: 600; display: flex; align-items: center; gap: 1rem;
        }
        .nav-item:hover { background: rgba(255,255,255,0.05); color: white; }
        .nav-item.active { background: #6366f1; color: white; }
        
        .main-content { margin-left: 280px; flex: 1; padding: 3rem; }

        .inventory-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 1.25rem;
            border-radius: 16px;
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .badge { padding: 0.25rem 0.6rem; border-radius: 6px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
        .badge-open { background: rgba(99, 102, 241, 0.1); color: #6366f1; }
        .badge-returned { background: rgba(34, 197, 94, 0.1); color: #22c55e; }

        .action-group { display: flex; gap: 0.75rem; align-items: center; }
        .btn-danger { background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 1px solid rgba(244, 63, 94, 0.2); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; transition: 0.3s; }
        .btn-danger:hover { background: #f43f5e; color: white; }
        
        select { background: rgba(0,0,0,0.3); color: white; border: 1px solid rgba(255,255,255,0.1); padding: 0.5rem; border-radius: 8px; font-size: 0.8rem; outline: none; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <a href="/" class="sidebar-brand">CampusLost</a>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">🏠 Dashboard</a>
            <a href="/admin/claims" class="nav-item">📋 Global Claims</a>
            <a href="/admin/items" class="nav-item active">📦 Global Items</a>
            <a href="/admin/users" class="nav-item">👥 User Directory</a>
            <a href="/items" class="nav-item">🌐 Browse View</a>
        </nav>
        <div style="margin-top: auto; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.05);">
            <a href="/logout" class="nav-item">🚪 Logout</a>
        </div>
    </aside>

    <main class="main-content">
        <header style="margin-bottom: 3rem;">
            <h1>Global Inventory Management</h1>
            <p style="color: #94a3b8; margin-top: 0.5rem;">Manage, update, or remove every item in the system.</p>
        </header>

        <% if (success_msg && success_msg.length > 0) { %>
            <div style="background: rgba(34, 197, 94, 0.1); color: #22c55e; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(34, 197, 94, 0.2);">
                <%= success_msg %>
            </div>
        <% } %>

        <div style="margin-bottom: 2rem; background: rgba(255,255,255,0.01); padding: 1rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
            <p style="color: #94a3b8; font-size: 0.9rem;">Total Items Tracked: <strong><%= items.length %></strong></p>
        </div>

        <% if (items.length > 0) { %>
            <% items.forEach(item => { %>
                <div class="inventory-card">
                    <div style="display: flex; align-items: center; gap: 1.5rem;">
                        <img src="<%= item.imageUrl %>" style="width: 60px; height: 60px; border-radius: 12px; object-fit: cover; background: #1a1a1a;">
                        <div>
                            <h3 style="margin:0; font-size: 1.1rem;"><%= item.title %></h3>
                            <div style="display: flex; gap: 1rem; margin-top: 0.25rem;">
                                <span style="font-size: 0.75rem; color: #6366f1; font-weight: 600;"><%= item.itemType.toUpperCase() %></span>
                                <span style="font-size: 0.75rem; color: #94a3b8;">by <%= item.reporter ? item.reporter.username : 'Unknown' %></span>
                                <span style="font-size: 0.75rem; color: #94a3b8;">📍 <%= item.location %></span>
                            </div>
                        </div>
                    </div>

                    <div class="action-group">
                        <span class="badge badge-<%= item.status %>"><%= item.status %></span>
                        
                        <!-- Fixed Delete Form -->
                        <form action="/admin/items/<%= item._id %>/delete" method="POST" onsubmit="return confirm('WARNING: This will permanently delete this item and all its claims. Proceed?')">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="text-align: center; padding: 5rem;">
                <p style="color: #94a3b8;">Platform inventory is currently empty.</p>
                <a href="/report" class="btn btn-primary" style="margin-top: 1rem; display: inline-block;">Report First Item</a>
            </div>
        <% } %>
    </main>
</body>
</html>
